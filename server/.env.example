# ─────────────────────────────────────────────────────────────────────────
# Clara – Avery Wellness Clinic Voice Agent · server environment
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────

# LiveKit — local dev server (started via `livekit-server --dev`).
# These default credentials are baked into LiveKit's dev mode; no signup needed.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Speech-to-Text + Text-to-Speech — both use your Deepgram key (Nova STT + Aura TTS).
# Get one free at https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key

# LLM — Groq (OpenAI-compatible). Runs llama-3.3-70b-versatile.
# Get one free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# PostgreSQL — local clara_clinic database (see schema.sql).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clara_clinic
DB_USER=postgres
DB_PASSWORD=your_password
